{
  "name": "jwp-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env dev --port 8080",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "db:migrate:remote": "npx wrangler d1 execute jwp-db --remote --file=../schema.sql",
    "db:migrate:local": "npx wrangler d1 execute jwp-db --local --file=../schema.sql",
    "reset:remote": "bash scripts/reset-remote.sh",
    "reset:remote:force": "bash scripts/reset-remote-force.sh",
    "db:clear:remote": "bash scripts/reset-remote.sh",
    "db:clear:remote:force": "bash scripts/reset-remote-force.sh"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
