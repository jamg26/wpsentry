# Copy this file to .dev.vars and fill in values for local development.
# Never commit .dev.vars — it is gitignored.
# Usage: wrangler dev --env dev
JWT_SECRET=your-random-32-char-secret-here
ADMIN_PASSWORD=your-admin-password
RESEND_API_KEY=
BREVO_API_KEY=
# Ollama Cloud API key — get one at https://ohmyollama.com
OLLAMA_API_KEY=
